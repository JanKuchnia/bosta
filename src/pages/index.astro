---
import Base from '@/layouts/Base.astro';
import Nav from '@/components/Nav.astro';
import Hero from '@/components/Hero.astro';
import Lead from '@/components/Lead.astro';
import ProductSegments from '@/components/ProductSegments.astro';
import Durability from '@/components/Durability.astro';
import ProcessTimeline from '@/components/ProcessTimeline.astro';
import Certifications from '@/components/Certifications.astro';
import HowWeWork from '@/components/HowWeWork.astro';
import About from '@/components/About.astro';
import ContactSection from '@/components/ContactSection.astro';
import Footer from '@/components/Footer.astro';
import Lightbox from '@/components/Lightbox';
---

<Base>
  <Nav />
  <main>
    <Hero />
    <Lead />
    <ProductSegments />
    <Durability />
    <ProcessTimeline />
    <Certifications />
    <HowWeWork />
    <About />
    <ContactSection />
  </main>
  <Footer />

  <!-- Global lightbox island — intercepts [data-lightbox] clicks -->
  <Lightbox client:load />
</Base>
