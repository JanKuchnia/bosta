---
// Placeholder workshop/craftsmanship image
const aboutImage = 'https://images.unsplash.com/photo-1476820865390-c52aeebb9891?auto=format&fit=crop&w=1200&q=80';
---

<section id="o-firmie" class="section-pad bg-canvas border-t border-border-subtle" aria-label="O firmie">
  <div class="container-site">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      <!-- Image -->
      <div class="reveal reveal-d1 relative aspect-[4/3] overflow-hidden order-2 lg:order-1">
        <img
          src={aboutImage}
          alt="Zakład produkcyjny BOSTA — rzemiosło i precyzja od 1992 roku"
          class="img-cover"
          loading="lazy"
          width="1200"
          height="900"
        />
        <!-- Year badge -->
        <div class="absolute top-6 left-6 bg-graphite-dark/90 px-4 py-3">
          <span class="font-display font-black text-4xl text-white leading-none">1992</span>
          <p class="label-caps text-white/60 mt-1">rok założenia</p>
        </div>
      </div>

      <!-- Text -->
      <div class="order-1 lg:order-2">
        <p class="reveal label-caps text-beech mb-4">O firmie</p>
        <h2 class="reveal reveal-d1 display-lg text-ink mb-6">
          Ponad trzy<br />dekady produkcji
        </h2>
        <p class="reveal reveal-d2 editorial-body text-ink-muted mb-8 leading-relaxed">
          BOSTA Producent Mebli Szkolnych i Biurowych Sp. z o.o. działa w Myślenicach od 1992 roku.
          Od lokalnej stolarni do zakładu z własnym parkiem CNC, spawalnią i lakiernią proszkową.
          Zarządzana przez założycieli — Karola Lenarta i Stanisława Bajera — firma utrzymuje bezpośrednią
          kontrolę nad całym procesem wytwórczym.
        </p>

        <!-- Locations -->
        <div class="reveal reveal-d3 grid sm:grid-cols-2 gap-6 mb-10">
          <div class="border-l-2 border-cta pl-4">
            <p class="font-display font-bold text-ink text-sm mb-1 tracking-tight">Centrum logistyczno-handlowe</p>
            <address class="not-italic text-sm text-ink-muted leading-relaxed">
              ul. Drogowców 7<br />
              32-400 Myślenice
            </address>
          </div>
          <div class="border-l-2 border-cta pl-4">
            <p class="font-display font-bold text-ink text-sm mb-1 tracking-tight">Zakład produkcyjny</p>
            <address class="not-italic text-sm text-ink-muted leading-relaxed">
              Polanka 133<br />
              32-400 Myślenice
            </address>
          </div>
        </div>

        <!-- Management -->
        <div class="reveal reveal-d4 border-t border-border-subtle pt-8">
          <p class="label-caps text-ink-muted mb-4">Zarząd</p>
          <div class="flex flex-col gap-3">
            <div>
              <p class="font-display font-bold text-ink text-sm tracking-tight">Karol Lenart</p>
              <p class="text-xs text-ink-muted">Prezes Zarządu</p>
            </div>
            <div>
              <p class="font-display font-bold text-ink text-sm tracking-tight">Stanisław Bajer</p>
              <p class="text-xs text-ink-muted">Wiceprezes Zarządu</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
