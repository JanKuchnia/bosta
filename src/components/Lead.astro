<section class="section-pad bg-canvas" aria-label="O BOSTA">
  <div class="container-site">
    <div class="max-w-3xl mx-auto text-center">
      <p class="reveal label-caps text-beech mb-8">Nasze podejście</p>

      <blockquote class="reveal reveal-d1 editorial-body text-ink mb-10 leading-relaxed" style="font-size: clamp(1.2rem, 2vw + 0.6rem, 1.5rem);">
        Od ponad trzydziestu lat BOSTA tworzy meble, których w polskich szkołach
        nie udaje się zniszczyć. Wzmocnione profile stalowe, sklejka bukowa,
        własna lakiernia proszkowa — cały proces pod jednym dachem, w Myślenicach.
        Dwa zakłady, jeden standard: trwałość, która nie jest kompromisem.
      </blockquote>

      <!-- Key facts as prose markers -->
      <div class="reveal reveal-d2 flex flex-wrap justify-center gap-x-10 gap-y-4 mt-10">
        <div class="flex flex-col items-center gap-1">
          <span class="font-display font-extrabold text-4xl tracking-tight text-ink">1992</span>
          <span class="label-caps text-ink-muted">rok założenia</span>
        </div>
        <div class="w-px bg-border-subtle hidden sm:block self-stretch"></div>
        <div class="flex flex-col items-center gap-1">
          <span class="font-display font-extrabold text-4xl tracking-tight text-ink">2</span>
          <span class="label-caps text-ink-muted">zakłady w Myślenicach</span>
        </div>
        <div class="w-px bg-border-subtle hidden sm:block self-stretch"></div>
        <div class="flex flex-col items-center gap-1">
          <span class="font-display font-extrabold text-4xl tracking-tight text-ink">100%</span>
          <span class="label-caps text-ink-muted">produkcja własna</span>
        </div>
        <div class="w-px bg-border-subtle hidden sm:block self-stretch"></div>
        <div class="flex flex-col items-center gap-1">
          <span class="font-display font-extrabold text-4xl tracking-tight text-ink">PL</span>
          <span class="label-caps text-ink-muted">cały kraj</span>
        </div>
      </div>
    </div>
  </div>
</section>
