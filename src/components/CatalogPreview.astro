---
import { ArrowRight } from 'lucide-react';
import { catalogCategories } from '@/data/catalog';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const totalProducts = catalogCategories.reduce((acc, cat) => acc + cat.products.length, 0);

// Flagship product: school desk — most recognisable, has a real price
const featured = catalogCategories[0].products[0];
---

<section
  class="section-pad bg-graphite-dark"
  aria-label="Katalog produktów i cennik"
  id="cennik"
>
  <div class="container-site">

    <!-- Section header -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-14">
      <div class="max-w-xl">
        <p class="reveal label-caps text-beech mb-4">Cennik i katalog</p>
        <h2 class="reveal reveal-d1 display-lg text-white">
          {catalogCategories.length} kategorii.<br />Ceny brutto.
        </h2>
      </div>
      <div class="reveal reveal-d2 shrink-0">
        <a
          href={`${base}/produkty`}
          class="inline-flex items-center gap-2 h-11 px-6 bg-gold text-ink font-display font-semibold text-sm tracking-tight"
        >
          Przeglądaj katalog
          <ArrowRight className="w-4 h-4" />
        </a>
      </div>
    </div>

    <!-- Body: category list + featured card -->
    <div class="grid lg:grid-cols-[1fr_340px] xl:grid-cols-[1fr_380px] gap-8 lg:gap-14 items-start">

      <!-- Category directory -->
      <div class="reveal">
        <ul class="grid sm:grid-cols-2 gap-px bg-white/10 border border-white/10" role="list">
          {catalogCategories.map(cat => (
            <li class="bg-graphite-dark">
              <a
                href={`${base}/produkty`}
                class="flex items-center justify-between px-5 py-3.5 hover:bg-white/5 transition-colors group"
              >
                <span class="text-sm text-white/70 group-hover:text-white transition-colors leading-snug">
                  {cat.name}
                </span>
                <span class="font-display font-bold text-xs text-cta tabular-nums ml-4 shrink-0">
                  {cat.products.length}
                </span>
              </a>
            </li>
          ))}
        </ul>

        <p class="mt-5 text-xs text-white/35 font-display">
          {totalProducts} produktów · aktualizowane {new Date().getFullYear()}
        </p>
      </div>

      <!-- Featured product card -->
      <div class="reveal reveal-d2 hidden lg:flex flex-col border border-white/15 overflow-hidden">
        <!-- Card header -->
        <div class="flex items-baseline justify-between gap-4 px-4 py-3 bg-white/10 shrink-0">
          <h3 class="font-display font-bold text-sm text-white leading-snug">
            {featured.name}
          </h3>
          <span class="text-[10px] font-display font-medium uppercase tracking-widest text-white/30 shrink-0">
            cena brutto
          </span>
        </div>

        <!-- Product image -->
        <div class="bg-white flex items-center justify-center p-6 shrink-0" style="height: 11rem;">
          <img
            src={featured.image}
            alt={featured.imageAlt}
            class="max-h-36 w-auto max-w-full object-contain"
            loading="lazy"
          />
        </div>

        <!-- Variants -->
        <div class="divide-y divide-white/10">
          {featured.variants.map(v => (
            <div class={`flex items-start justify-between gap-4 px-4 py-3 ${v.isAddon ? 'opacity-55' : ''}`}>
              <p class="text-xs text-white/65 leading-snug">{v.description}</p>
              <div class="text-right shrink-0">
                {v.price > 0 ? (
                  <div class="font-display font-black text-sm text-white tabular-nums whitespace-nowrap leading-none">
                    {v.price.toLocaleString('pl-PL')}
                    <span class="text-xs font-normal text-white/40 ml-0.5">PLN</span>
                  </div>
                ) : (
                  <span class="text-xs text-white/40 font-display italic">na zapytanie</span>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Card footer -->
        <div class="px-4 py-3 border-t border-white/10 mt-auto shrink-0">
          <p class="text-[10px] text-white/30 font-display">
            + {totalProducts - featured.variants.length} wariantów w pełnym katalogu
          </p>
        </div>
      </div>

    </div>
  </div>
</section>
