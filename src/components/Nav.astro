---
import MobileNav from './MobileNav.tsx';

const navLinks = [
  { href: '#produkty',    label: 'Produkty' },
  { href: '#proces',      label: 'Proces' },
  { href: '#certyfikaty', label: 'Certyfikaty' },
  { href: '#o-firmie',    label: 'O firmie' },
  { href: '#kontakt',     label: 'Kontakt' },
];
---

<header
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50"
  aria-label="Nawigacja główna"
>
  <div class="container-site flex items-center justify-between h-16 md:h-20">
    <!-- Wordmark -->
    <a href="/" class="nav-logo font-display font-extrabold text-2xl tracking-tighter text-white transition-colors" aria-label="BOSTA — strona główna">
      BOSTA
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-8" aria-label="Menu">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="nav-link label-caps text-white/80 hover:text-white transition-colors"
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA + mobile toggle -->
    <div class="flex items-center gap-3">
      <a
        href="#kontakt"
        class="hidden sm:inline-flex items-center h-9 px-5 bg-gold text-ink font-display font-semibold text-sm tracking-tight"
      >
        Zapytaj o wycenę
      </a>

      <MobileNav client:load />
    </div>
  </div>
</header>

<script>
  const nav = document.getElementById('site-nav')!;

  const SCROLL_THRESHOLD = 80;
  function updateNav() {
    nav.classList.toggle('nav-solid', window.scrollY > SCROLL_THRESHOLD);
  }
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();
</script>
